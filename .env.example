# =============================================================
# AutoCityIntro 配置模板（脱敏）
# 用法：复制为 .env 并填入真实值。.env 由 load_dotenv() 自动加载，
#       切勿将填好真实 Key 的 .env 提交到代码仓库。
# =============================================================

# ---------- 大模型 (OpenAI 兼容接口，默认 Kimi/Moonshot) ----------
# API Key（必填）。Kimi 申请：https://platform.moonshot.cn
OPENAI_API_KEY=sk-your-openai-compatible-api-key
# 接口地址，留空使用 Moonshot 官方
OPENAI_BASE_URL=https://api.moonshot.cn/v1
# 模型名
OPENAI_MODEL=kimi-k2.6
# 是否开启 thinking 模式：enabled / disabled
OPENAI_THINKING=disabled
# 采样温度（开启 thinking 建议 1，关闭时 kimi-k2.6 仅允许 0.6）
OPENAI_TEMPERATURE=0.6
# 意图分类专用温度（kimi 非 thinking 模式固定 0.6）
INTENT_LLM_TEMPERATURE=0.6

# ---------- 高德地图 ----------
# REST 服务端 Key（必填）。申请：https://console.amap.com
AMAP_API_KEY=your-amap-rest-api-key
# Web 端 JS API Key（可选，未配置时前端回退使用 AMAP_API_KEY）
AMAP_JS_KEY=
# 高德安全密钥（Web 端 JS API 安全密钥，可选；部分 Key 类型需要）
# AMAP_JS_SECURITY=

# ---------- OpenWeatherMap ----------
# 申请：https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ---------- MiniMax (语音合成 / 图像生成) ----------
# 申请：https://www.minimax.cn/platform
MINIMAX_API_KEY=your-minimax-api-key
# 新版端点（与 Cursor MCP 一致），Header Bearer 鉴权，无需 GroupId
MINIMAX_API_HOST=https://api.minimaxi.com
# TTS 模型，新版默认 speech-2.6-hd
MINIMAX_TTS_MODEL=speech-2.6-hd
# GroupId 仅旧端点 api.minimax.chat 需要；用 minimaxi.com 时可留空
MINIMAX_GROUP_ID=

# =============================================================
# 以下为非敏感运行参数，按需调整；未设置时代码使用默认值
# =============================================================
# WEB_PORT=7003
# WEB_BASE_URL=http://localhost:7003
# MCP_SERVER_URL=http://localhost:7001
# MCP_TIMEOUT=25
# MCP_MAX_RETRIES=2
# MCP_CACHE_ENABLED=true
# SPEECH_ENABLED=true
# MINOR_MODE=false
# AUDIO_OUTPUT_DIR=data/audio
# IMAGE_OUTPUT_DIR=data/images
# PROFILE_DATA_DIR=data/profiles
